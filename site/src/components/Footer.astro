---
import { brand, homeContent, localizedPaths, type Locale } from '../config/site';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const copy = homeContent[locale].footer;
---

<footer class="site-footer">
	<div class="container site-footer__grid">
		<div class="site-footer__brand">
			<div class="brand-mark brand-mark--footer">
				<span class="brand-mark__star" aria-hidden="true"></span>
				<span>{brand.name}</span>
			</div>
			<p>{copy.blurb}</p>
		</div>

		<div>
			<p class="footer-heading">{copy.legal}</p>
			<ul class="footer-links">
				<li><a href={localizedPaths.privacy[locale]}>{copy.privacy}</a></li>
				<li><a href={localizedPaths.terms[locale]}>{copy.terms}</a></li>
				<li><a href={localizedPaths.dataDeletion[locale]}>{copy.dataDeletion}</a></li>
			</ul>
		</div>

		<div>
			<p class="footer-heading">Contact</p>
			<ul class="footer-links">
				<li><a href={`mailto:${brand.salesEmail}`}>{brand.salesEmail}</a></li>
				<li><a href={`mailto:${brand.privacyEmail}`}>{brand.privacyEmail}</a></li>
				<li><a href={`https://wa.me/${brand.whatsappE164}`} target="_blank" rel="noreferrer">{brand.whatsappDisplay}</a></li>
			</ul>
		</div>
	</div>
</footer>
