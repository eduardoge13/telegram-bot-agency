---
import LegalPage from '../components/LegalPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { localizedPaths, privacyPolicyContent } from '../config/site';

const copy = privacyPolicyContent.es;
---

<BaseLayout
	locale="es"
	title={`Blue Sky Travel | ${copy.title}`}
	description={copy.description}
	path={localizedPaths.privacy.es}
	alternatePath={localizedPaths.privacy.en}
>
	<LegalPage
		locale="es"
		title={copy.title}
		intro={copy.intro}
		description={copy.description}
		contactCard={copy.contactCard}
		sections={copy.sections}
	/>
</BaseLayout>
