---
import BaseLayout from '../layouts/BaseLayout.astro';
import { dataDeletionContent, localizedPaths, brand } from '../config/site';

const copy = dataDeletionContent.es;
---

<BaseLayout
	locale="es"
	title={`Blue Sky Travel | ${copy.title}`}
	description={copy.description}
	path={localizedPaths.dataDeletion.es}
	alternatePath={localizedPaths.dataDeletion.en}
>
	<main class="legal-main">
		<section class="legal-hero">
			<div class="container legal-hero__grid">
				<div>
					<p class="eyebrow">Legal</p>
					<h1>{copy.title}</h1>
					<p class="lead">{copy.intro}</p>
				</div>
				<div class="legal-contact-card">
					<h2>Contacto</h2>
					<p>Usa este canal para solicitudes vinculadas con acceso, corrección o eliminación de información.</p>
					<dl class="contact-list">
						<dt>Correo</dt>
						<dd>{brand.privacyEmail}</dd>
						<dt>WhatsApp</dt>
						<dd>{brand.whatsappDisplay}</dd>
					</dl>
				</div>
			</div>
		</section>

		<section class="legal-warning">
			<div class="container">
				<p>{copy.timing}</p>
			</div>
		</section>

		<section class="legal-sections">
			<div class="container legal-section-grid">
				<article class="legal-card">
					<h2>Proceso recomendado</h2>
					<ul class="legal-list">
						{copy.steps.map((step) => <li>{step}</li>)}
					</ul>
				</article>
			</div>
		</section>
	</main>
</BaseLayout>
