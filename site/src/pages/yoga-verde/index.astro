    <div class="pointer-events-none fixed inset-0 z-[82] bg-primary/25 opacity-0 transition-opacity" data-cart-overlay></div>
    <aside
      class="fixed right-0 top-0 z-[83] flex h-full w-full max-w-[460px] translate-x-full flex-col bg-surface-container-lowest shadow-[0_24px_80px_rgba(23,48,32,0.22)] transition-transform duration-300"
      data-cart-drawer
    >
      <div class="flex items-center justify-between border-b border-outline-variant/40 px-6 py-5">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-on-surface-variant">Carrito interactivo</p>
          <h2 class="font-headline text-4xl text-primary">Tu cosecha</h2>
        </div>
        <button
          aria-label="Cerrar carrito"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/50 text-primary transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
          data-close-cart
          type="button"
        >
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <div class="hide-scrollbar flex-1 overflow-y-auto px-6 py-6">
        <div class="rounded-[28px] bg-surface-container-low p-5 shadow-parchment">
          <div class="flex items-center justify-between gap-3">
            <p class="text-sm font-semibold text-primary">Progreso de envío consciente</p>
            <p class="text-xs uppercase tracking-[0.22em] text-on-surface-variant">
              Meta {formatMoney(FREE_SHIPPING_THRESHOLD)}
            </p>
          </div>
          <div class="mt-4 h-3 overflow-hidden rounded-full bg-surface-container-highest">
            <div class="h-full rounded-full bg-secondary transition-all duration-300" data-shipping-progress style="width: 0%"></div>
          </div>
          <p class="mt-4 text-sm leading-7 text-on-surface-variant" data-shipping-message>
            Te faltan {formatMoney(FREE_SHIPPING_THRESHOLD)} para envío gratis.
          </p>
        </div>

        <div class="mt-6 space-y-4" data-cart-items></div>

        <div class="mt-6 hidden rounded-[28px] bg-surface-container-low p-6 text-center shadow-parchment" data-cart-empty>
          <span class="material-symbols-outlined text-5xl text-on-surface-variant/40">shopping_bag</span>
          <p class="mt-4 font-headline text-3xl text-primary">Tu canasta está vacía</p>
          <p class="mt-3 text-on-surface-variant">
            Explora el catálogo, suma kits o empieza por un ritual según tu necesidad.
          </p>
        </div>

        <div class="mt-6 rounded-[28px] bg-primary p-6 text-on-primary shadow-float">
          <div class="mb-4 flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary">local_shipping</span>
            <h3 class="font-headline text-3xl italic text-on-primary-container">Envío seguro</h3>
          </div>
          <p class="leading-8 text-on-primary-container/95">
            Empaque reciclado, protección ligera y despachos preparados con el mismo cuidado con
            el que seleccionamos cada planta.
          </p>
        </div>

        <div class="mt-6 rounded-[28px] bg-surface-container-low p-5 shadow-parchment" data-cart-upsell></div>
      </div>

      <div class="border-t border-outline-variant/40 bg-surface px-6 py-6">
        <div class="space-y-3 text-sm text-on-surface-variant">
          <div class="flex items-center justify-between">
            <span>Subtotal</span>
            <span data-subtotal>{formatMoney(0)}</span>
          </div>
          <div class="flex items-center justify-between">
            <span>Envío consciente</span>
            <span data-shipping>{formatMoney(0)}</span>
          </div>
          <div class="flex items-center justify-between">
            <span>Impuestos</span>
            <span data-tax>{formatMoney(0)}</span>
          </div>
        </div>
        <div class="mt-5 flex items-end justify-between gap-5 border-t border-outline-variant/50 pt-5">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-on-surface-variant">Total</p>
            <p class="font-headline text-4xl text-primary" data-total>{formatMoney(0)}</p>
          </div>
          <button
            class="inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-4 font-semibold text-on-primary transition hover:bg-primary-container disabled:cursor-not-allowed disabled:opacity-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
            data-checkout
            disabled
            type="button"
          >
            Continuar con el pedido
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </button>
        </div>
      </div>
    </aside>

    <div class="pointer-events-none fixed inset-0 z-[88] bg-primary/35 opacity-0 transition-opacity" data-modal-overlay></div>
    <div
      aria-labelledby="detail-title"
      aria-modal="true"
      class="pointer-events-none fixed left-1/2 top-1/2 z-[89] w-[min(94vw,760px)] -translate-x-1/2 -translate-y-1/2 scale-95 rounded-[32px] bg-surface-container-lowest p-6 opacity-0 shadow-float transition-all sm:p-8"
      data-detail-modal
      role="dialog"
    >
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-secondary" data-detail-badge>Sabiduría botánica</p>
          <h2 class="mt-2 font-headline text-4xl text-primary sm:text-5xl" data-detail-title id="detail-title"></h2>
        </div>
        <button
          aria-label="Cerrar detalle"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/50 text-primary transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
          data-close-detail
          type="button"
        >
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <div class="mt-8 grid gap-8 md:grid-cols-[240px_minmax(0,1fr)] md:items-start">
        <div class="overflow-hidden rounded-[26px] bg-surface-container-low p-4">
          <img alt="" class="aspect-square w-full rounded-[20px] object-cover" data-detail-image src="" />
        </div>
        <div>
          <div class="flex flex-wrap items-center gap-3 text-sm text-on-surface-variant">
            <div class="flex items-center gap-1 text-secondary" data-detail-rating-stars></div>
            <span data-detail-rating-copy></span>
          </div>
          <p class="mt-5 text-base leading-8 text-on-surface-variant" data-detail-description></p>
          <div class="mt-6 flex flex-wrap gap-2" data-detail-tags></div>

          <div class="mt-6 grid gap-5 rounded-[28px] bg-surface-container-low p-5">
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-on-surface-variant">Beneficios</p>
              <ul class="mt-3 space-y-3 text-sm leading-7 text-on-surface-variant" data-detail-benefits></ul>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-on-surface-variant">Cómo integrarlo</p>
              <p class="mt-3 text-sm leading-7 text-on-surface-variant" data-detail-instructions></p>
            </div>
          </div>

          <div class="mt-8 flex items-center justify-between gap-4 border-t border-outline-variant/40 pt-6">
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-on-surface-variant">Precio</p>
              <p class="font-headline text-4xl text-primary" data-detail-price></p>
            </div>
            <button
              class="inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-4 font-semibold text-on-primary transition hover:bg-primary-container focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
              data-detail-add
              type="button"
            >
              Añadir al carrito
              <span class="material-symbols-outlined text-lg">add_shopping_cart</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <script defer is:inline src="/yoga-verde/shop.js"></script>
  </body>
</html>
