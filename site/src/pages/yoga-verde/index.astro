---
import {
  ANNOUNCEMENT,
  BENEFIT_ITEMS,
  FREE_SHIPPING_THRESHOLD,
  KITS,
  PRODUCTS,
  SHIPPING_FLAT,
  SHOP_NEEDS,
  TAX_RATE,
  TESTIMONIALS,
} from "../../data/yoga-verde-store";
import "../../styles/yoga-verde.css";

const money = new Intl.NumberFormat("es-MX", {
  style: "currency",
  currency: "MXN",
  maximumFractionDigits: 0,
});

const formatMoney = (value: number) => money.format(value);
const stars = Array.from({ length: 5 }, (_, index) => index + 1);

const bestSellers = PRODUCTS.filter((product) => product.featured).slice(0, 4);

const useFilters = Array.from(
  new Map(PRODUCTS.map((product) => [product.use, { slug: product.use, label: product.useLabel }])).values(),
);
const typeFilters = Array.from(
  new Map(PRODUCTS.map((product) => [product.type, { slug: product.type, label: product.typeLabel }])).values(),
);
const originFilters = Array.from(
  new Map(
    PRODUCTS.map((product) => [product.origin, { slug: product.origin, label: product.originLabel }]),
  ).values(),
);
const countsByUse = Object.fromEntries(
  SHOP_NEEDS.map((need) => [need.slug, PRODUCTS.filter((product) => product.use === need.slug).length]),
);

const storeData = {
  announcement: ANNOUNCEMENT,
  freeShippingThreshold: FREE_SHIPPING_THRESHOLD,
  shippingFlat: SHIPPING_FLAT,
  taxRate: TAX_RATE,
  products: PRODUCTS,
  kits: KITS,
};
---

<html class="light" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Yoga Verde | Herbolario ancestral y tienda botánica</title>
    <meta
      content="Yoga Verde es un herbolario ancestral con shop-first experience: botánicos curados, kits, filtros vivos y carrito para comprar fácil desde móvil o desktop."
      name="description"
    />
    <meta content="Yoga Verde | Herbolario ancestral y tienda botánica" property="og:title" />
    <meta
      content="Compra raíces, hojas y kits con una experiencia comercial clara, móvil y fiel al universo botánico de Yoga Verde."
      property="og:description"
    />
    <meta content="website" property="og:type" />
    <meta content="https://yoga-verde.srv1175749.hstgr.cloud/" property="og:url" />
    <meta
      content="https://yoga-verde.srv1175749.hstgr.cloud/yoga-verde/assets/image-01.png"
      property="og:image"
    />
    <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&family=Manrope:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link href="https://yoga-verde.srv1175749.hstgr.cloud/" rel="canonical" />
  </head>
  <body class="bg-surface text-on-surface selection:bg-secondary/20 selection:text-primary">
    <script id="yoga-verde-data" is:inline set:html={JSON.stringify(storeData)} type="application/json"></script>

    <div class="min-h-screen bg-surface pb-28 md:pb-0">
      <div class="sticky top-0 z-[70]">
        <div class="bg-primary px-4 py-2 text-center text-[11px] font-semibold uppercase tracking-[0.22em] text-on-primary-container sm:text-xs">
          {ANNOUNCEMENT}
        </div>
        <header class="border-b border-outline-variant/45 bg-[#fcf9f0]/90 backdrop-blur-xl">
          <nav class="mx-auto flex h-20 max-w-screen-2xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
            <div class="flex items-center gap-3">
              <button
                aria-label="Abrir menú"
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/60 bg-surface-container-lowest text-primary transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40 md:hidden"
                data-open-menu
                type="button"
              >
                <span class="material-symbols-outlined">menu</span>
              </button>
              <a class="font-headline text-3xl font-semibold tracking-tight text-primary" href="#inicio">
                Yoga Verde
              </a>
            </div>

            <div class="hidden items-center gap-7 md:flex">
              <button
                class="text-sm font-medium text-on-surface-variant transition-colors hover:text-secondary focus-visible:outline-none focus-visible:text-secondary"
                data-scroll-to="inicio"
                type="button"
              >
                Inicio
              </button>
              <button
                class="text-sm font-medium text-on-surface-variant transition-colors hover:text-secondary focus-visible:outline-none focus-visible:text-secondary"
                data-scroll-to="best-sellers"
                type="button"
              >
                Best Sellers
              </button>
              <button
                class="border-b-2 border-secondary pb-1 font-headline text-lg font-semibold text-secondary"
                data-scroll-to="catalogo"
                type="button"
              >
                Catálogo
              </button>
              <button
                class="text-sm font-medium text-on-surface-variant transition-colors hover:text-secondary focus-visible:outline-none focus-visible:text-secondary"
                data-scroll-to="kits"
                type="button"
              >
                Kits
              </button>
              <button
                class="text-sm font-medium text-on-surface-variant transition-colors hover:text-secondary focus-visible:outline-none focus-visible:text-secondary"
                data-scroll-to="testimonios"
                type="button"
              >
                Testimonios
              </button>
              <button
                class="text-sm font-medium text-on-surface-variant transition-colors hover:text-secondary focus-visible:outline-none focus-visible:text-secondary"
                data-scroll-to="contacto"
                type="button"
              >
                Contacto
              </button>
            </div>

            <div class="flex items-center gap-3">
              <button
                aria-label="Buscar en el catálogo"
                class="hidden items-center gap-2 rounded-full border border-outline-variant/60 bg-surface-container-low px-4 py-2 text-sm text-on-surface-variant transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35 lg:inline-flex"
                data-focus-search
                type="button"
              >
                <span class="material-symbols-outlined text-base">search</span>
                Buscar botánicos
              </button>
              <button
                aria-label="Abrir carrito"
                class="group relative inline-flex h-12 w-12 items-center justify-center rounded-full border border-outline-variant/50 bg-surface-container-lowest text-primary transition hover:-translate-y-0.5 hover:border-secondary/50 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
                data-open-cart
                type="button"
              >
                <span class="material-symbols-outlined">shopping_cart</span>
                <span
                  class="absolute -right-1 -top-1 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-secondary px-1 text-[10px] font-bold text-white"
                  data-cart-count
                >
                  0
                </span>
              </button>
            </div>
          </nav>
        </header>
      </div>

      <main>
        <section class="paper-grid relative overflow-hidden border-b border-outline-variant/35" id="inicio">
          <div class="mx-auto grid max-w-screen-2xl gap-12 px-4 py-14 sm:px-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,520px)] lg:items-center lg:px-8 lg:py-20">
            <div class="max-w-3xl">
              <span class="mb-5 inline-flex items-center gap-2 rounded-full border border-secondary/20 bg-secondary/10 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary sm:text-xs">
                <span class="material-symbols-outlined text-base">spa</span>
                Herbolario ancestral, listo para comprar
              </span>
              <h1 class="font-headline text-5xl leading-[0.92] text-primary sm:text-6xl lg:text-[6.1rem]">
                Botánica viva para tu
                <span class="block font-semibold italic text-secondary">ritual diario</span>
              </h1>
              <p class="mt-6 max-w-2xl text-lg leading-relaxed text-on-surface-variant sm:text-xl">
                Yoga Verde une curaduría editorial y claridad comercial: raíces, hojas y kits
                seleccionados para comprar fácil, desde móvil o desktop, sin perder el relato de
                origen botánico y cosecha ética.
              </p>

              <div class="mt-8 flex flex-col gap-4 sm:flex-row">
                <button
                  class="inline-flex items-center justify-center gap-2 rounded-2xl bg-primary px-7 py-4 text-base font-semibold text-on-primary transition hover:bg-primary-container focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
                  data-scroll-to="catalogo"
                  type="button"
                >
                  Comprar ahora
                  <span class="material-symbols-outlined text-lg">south_east</span>
                </button>
                <button
                  class="inline-flex items-center justify-center gap-2 rounded-2xl border border-outline-variant/60 bg-surface-container-lowest px-7 py-4 text-base font-semibold text-primary transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
                  data-scroll-to="kits"
                  type="button"
                >
                  Ver kits
                  <span class="material-symbols-outlined text-lg">inventory_2</span>
                </button>
              </div>

              <div class="mt-10 flex flex-wrap gap-3">
                <div class="rounded-2xl bg-surface-container-lowest px-5 py-4 shadow-parchment">
                  <p class="text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">
                    Botánicos vivos
                  </p>
                  <p class="mt-2 font-headline text-4xl text-primary">{PRODUCTS.length}</p>
                </div>
                <div class="rounded-2xl bg-surface-container-lowest px-5 py-4 shadow-parchment">
                  <p class="text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">
                    Kits curados
                  </p>
                  <p class="mt-2 font-headline text-4xl text-primary">{KITS.length}</p>
                </div>
                <div class="rounded-2xl bg-surface-container-lowest px-5 py-4 shadow-parchment">
                  <p class="text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">
                    Envío gratis
                  </p>
                  <p class="mt-2 font-headline text-4xl text-primary">
                    {formatMoney(FREE_SHIPPING_THRESHOLD)}
                  </p>
                </div>
              </div>
            </div>

            <div class="relative">
              <div class="card-grain relative overflow-hidden rounded-[36px] bg-soil-glow bg-surface-container-lowest p-4 shadow-float sm:p-6">
                <img
                  alt="Raíces vivas cubiertas de musgo"
                  class="aspect-[4/5] w-full rounded-[30px] object-cover"
                  src="/yoga-verde/assets/image-01.png"
                />
              </div>
              <div class="absolute -left-2 bottom-6 max-w-[220px] rounded-[28px] bg-surface-container-lowest p-5 shadow-parchment sm:-left-8">
                <p class="text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">
                  Best seller del mes
                </p>
                <h2 class="mt-2 font-headline text-3xl text-primary">Ashwagandha Vital</h2>
                <p class="mt-2 text-sm leading-6 text-on-surface-variant">
                  Un ritual diario para empezar con raíz, calma y estructura.
                </p>
                <button
                  class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-secondary transition hover:text-primary focus-visible:outline-none"
                  data-add-item="ashwagandha-vital"
                  type="button"
                >
                  Añadir al carrito
                  <span class="material-symbols-outlined text-base">add_shopping_cart</span>
                </button>
              </div>
              <div class="absolute -right-2 top-6 rounded-[28px] bg-primary px-5 py-4 text-on-primary shadow-line sm:-right-8">
                <p class="text-[11px] uppercase tracking-[0.22em] text-on-primary-container">
                  Compra protegida
                </p>
                <p class="mt-2 font-headline text-3xl text-white">Checkout demo</p>
                <p class="mt-2 max-w-[200px] text-sm leading-6 text-on-primary-container">
                  Hoy el pedido termina en demo, pero el carrito ya está listo para vender mejor.
                </p>
              </div>
            </div>
          </div>
        </section>

        <section class="mx-auto max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
            {BENEFIT_ITEMS.map((benefit) => (
              <article class="rounded-[28px] bg-surface-container-lowest p-5 shadow-parchment">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/8 text-primary">
                  <span class="material-symbols-outlined">{benefit.icon}</span>
                </div>
                <h2 class="mt-4 font-headline text-2xl text-primary">{benefit.title}</h2>
                <p class="mt-2 text-sm leading-7 text-on-surface-variant">{benefit.copy}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="mx-auto max-w-screen-2xl px-4 py-10 sm:px-6 lg:px-8" id="best-sellers">
          <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-2xl">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">
                Best Sellers
              </p>
              <h2 class="mt-3 font-headline text-5xl text-primary">Lo más pedido esta temporada</h2>
              <p class="mt-4 text-lg leading-8 text-on-surface-variant">
                Inspirado por las mejores prácticas comerciales de marcas directas al consumidor:
                selección clara, beneficios rápidos y compra simple sin perder el tono editorial.
              </p>
            </div>
            <button
              class="inline-flex items-center gap-2 rounded-full border border-outline-variant/60 bg-surface-container-lowest px-5 py-3 text-sm font-semibold text-primary transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
              data-scroll-to="catalogo"
              type="button"
            >
              Ver catálogo completo
              <span class="material-symbols-outlined text-base">arrow_forward</span>
            </button>
          </div>

          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
            {bestSellers.map((product) => (
              <article class="group overflow-hidden rounded-[30px] bg-surface-container-lowest shadow-parchment transition-transform hover:-translate-y-1">
                <div class="relative overflow-hidden bg-surface-container-low p-4">
                  <span class="absolute left-4 top-4 z-10 rounded-full bg-surface px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-primary">
                    {product.badge}
                  </span>
                  <img
                    alt={product.name}
                    class="aspect-[5/4] w-full rounded-[24px] object-cover transition duration-500 group-hover:scale-105"
                    src={product.image}
                  />
                </div>
                <div class="p-6">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">
                        {product.originLabel}
                      </p>
                      <h3 class="mt-2 font-headline text-4xl leading-none text-primary">{product.name}</h3>
                    </div>
                    <span class="font-headline text-3xl text-secondary">{formatMoney(product.price)}</span>
                  </div>
                  <div class="mt-4 flex items-center gap-3 text-sm text-on-surface-variant">
                    <div class="flex items-center gap-1 text-secondary">
                      {stars.map((star) => (
                        <span aria-hidden="true">{star <= Math.round(product.rating) ? "★" : "☆"}</span>
                      ))}
                    </div>
                    <span>{product.rating.toFixed(1)} · {product.reviewsCount} reseñas</span>
                  </div>
                  <p class="mt-4 text-sm italic leading-7 text-on-surface-variant">{product.short}</p>
                  <div class="mt-5 flex flex-wrap gap-2">
                    <span class="rounded-full bg-surface-container-low px-3 py-2 text-xs font-semibold text-primary">
                      {product.useLabel}
                    </span>
                    <span class="rounded-full bg-surface-container-low px-3 py-2 text-xs font-semibold text-on-surface-variant">
                      {product.typeLabel}
                    </span>
                  </div>
                  <div class="mt-6 flex items-center justify-between gap-3 border-t border-outline-variant/40 pt-5">
                    <button
                      class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition hover:text-secondary focus-visible:outline-none"
                      data-open-detail={product.id}
                      type="button"
                    >
                      <span class="material-symbols-outlined text-base">auto_stories</span>
                      Ver detalle
                    </button>
                    <button
                      class="inline-flex items-center gap-2 rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-on-primary transition hover:bg-primary-container focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
                      data-add-item={product.id}
                      type="button"
                    >
                      Añadir al carrito
                    </button>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="mx-auto max-w-screen-2xl px-4 py-10 sm:px-6 lg:px-8">
          <div class="mb-8 max-w-2xl">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">
              Comprar por necesidad
            </p>
            <h2 class="mt-3 font-headline text-5xl text-primary">Encuentra tu ritual por intención</h2>
            <p class="mt-4 text-lg leading-8 text-on-surface-variant">
              Una ruta más comercial para quienes llegan con una necesidad clara y quieren comprar
              sin perder contexto ni lenguaje de marca.
            </p>
          </div>

          <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
            {SHOP_NEEDS.map((need) => (
              <article class="overflow-hidden rounded-[32px] bg-surface-container-lowest shadow-parchment">
                <div class="relative overflow-hidden bg-primary/6 p-5">
                  <img
                    alt={need.title}
                    class="aspect-[4/3] w-full rounded-[24px] object-cover"
                    src={need.image}
                  />
                  <div class="absolute left-9 top-9 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-white shadow-line">
                    <span class="material-symbols-outlined">{need.icon}</span>
                  </div>
                </div>
                <div class="p-6">
                  <div class="flex items-center justify-between gap-4">
                    <h3 class="font-headline text-3xl text-primary">{need.title}</h3>
                    <span class="rounded-full bg-secondary/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.22em] text-secondary">
                      {countsByUse[need.slug]} opciones
                    </span>
                  </div>
                  <p class="mt-4 text-sm leading-7 text-on-surface-variant">{need.copy}</p>
                  <button
                    class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary transition hover:text-secondary focus-visible:outline-none"
                    data-apply-use={need.slug}
                    type="button"
                  >
                    Comprar esta selección
                    <span class="material-symbols-outlined text-base">arrow_forward</span>
                  </button>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="mx-auto max-w-screen-2xl px-4 py-10 sm:px-6 lg:px-8" id="kits">
          <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-2xl">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">
                Kits recomendados
              </p>
              <h2 class="mt-3 font-headline text-5xl text-primary">Comprar mejor, en menos pasos</h2>
              <p class="mt-4 text-lg leading-8 text-on-surface-variant">
                Diseñados para primera compra, regalo o ritual guiado. Aquí la experiencia se
                vuelve más directa, más móvil y más fácil de convertir.
              </p>
            </div>
            <button
              class="inline-flex items-center gap-2 rounded-full border border-outline-variant/60 bg-surface-container-lowest px-5 py-3 text-sm font-semibold text-primary transition hover:border-secondary/40 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
              data-open-cart
              type="button"
            >
              Ver carrito
              <span class="material-symbols-outlined text-base">shopping_bag</span>
            </button>
          </div>

          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
            {KITS.map((kit) => (
              <article class="overflow-hidden rounded-[30px] bg-surface-container-lowest shadow-parchment">
                <div class="relative overflow-hidden p-4">
                  <img alt={kit.name} class="aspect-[4/5] w-full rounded-[24px] object-cover" src={kit.image} />
                  <span class="absolute left-8 top-8 rounded-full bg-primary px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-white">
                    {kit.badge}
                  </span>
                </div>
                <div class="p-6">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">
                        {kit.useLabel}
                      </p>
                      <h3 class="mt-2 font-headline text-4xl leading-none text-primary">{kit.name}</h3>
                    </div>
                    <span class="font-headline text-3xl text-secondary">{formatMoney(kit.price)}</span>
                  </div>
                  <div class="mt-4 flex items-center gap-3 text-sm text-on-surface-variant">
                    <div class="flex items-center gap-1 text-secondary">
                      {stars.map((star) => (
                        <span aria-hidden="true">{star <= Math.round(kit.rating) ? "★" : "☆"}</span>
                      ))}
                    </div>
                    <span>{kit.rating.toFixed(1)} · {kit.reviewsCount} reseñas</span>
                  </div>
                  <p class="mt-4 text-sm italic leading-7 text-on-surface-variant">{kit.short}</p>
                  <div class="mt-5 flex flex-wrap gap-2">
                    <span class="rounded-full bg-surface-container-low px-3 py-2 text-xs font-semibold text-primary">
                      {kit.typeLabel}
                    </span>
                    <span class="rounded-full bg-surface-container-low px-3 py-2 text-xs font-semibold text-on-surface-variant">
                      Regalo o primera compra
                    </span>
                  </div>
                  <div class="mt-6 flex items-center justify-between gap-3 border-t border-outline-variant/40 pt-5">
                    <button
                      class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition hover:text-secondary focus-visible:outline-none"
                      data-open-detail={kit.id}
                      type="button"
                    >
                      <span class="material-symbols-outlined text-base">auto_stories</span>
                      Ver detalle
                    </button>
                    <button
                      class="inline-flex items-center gap-2 rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-on-primary transition hover:bg-primary-container focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/35"
                      data-add-item={kit.id}
                      type="button"
                    >
                      Añadir al carrito
                    </button>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="mx-auto max-w-screen-2xl px-4 py-12 sm:px-6 lg:px-8" id="catalogo">
